# Backend API URL — leave empty for local dev (Vite proxy handles it)
# For production, set to the full backend URL (e.g. https://api.cineflix.dev/api)
VITE_API_URL=

# TMDB API key — get one at https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# OMDb API key — get one at https://www.omdbapi.com/apikey.aspx (free tier: 1000 req/day)
VITE_OMDB_API_KEY=your_omdb_api_key_here

# Google OAuth Client ID — get one at https://console.cloud.google.com
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

#Extension
VITE_EXTENSION_ID=

VITE_CORS_PROXY_URL=

# Vidrock provider AES passphrase — required when the Vidrock/Granite scraper is enabled
VITE_VIDROCK_PASSPHRASE=

# CinePro Core Integration
VITE_CINEPRO_URL=http://localhost:3005
VITE_CINEPRO_ENABLED=true
VITE_CINEPRO_TIMEOUT=15000