    "iso-639-3": "^3.0.1",
    "jsonwebtoken": "^9.0.3",
    "lenis": "^1.3.25",
    "lodash.merge": "^4.6.2",
    "lucide-react": "^0.263.1",
    "mongoose": "^8.0.0",
    "nanoid": "^5.1.11",
    "ofetch": "^1.5.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
