    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dompurify": "^3.4.7",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
